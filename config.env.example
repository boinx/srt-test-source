# SRT Test Source — configuration
# setup.sh copies this to config.env on first run. Edit config.env (not this file),
# then (re)run ./run.sh. Values can also be overridden by exporting the env var.

# Source video for the 'teststream' stream (real video + real audio, stream-copied).
# If this file is missing, a generated test card is used instead — and the synthetic
# 'pattern' stream always works regardless, so a fresh clone runs with zero assets.
SRC_VIDEO="${SRC_VIDEO:-$HOME/Movies/srt-test.mp4}"

# Ports
SRT_PORT="${SRT_PORT:-8890}"     # SRT listener — receivers connect here (caller mode)
API_PORT="${API_PORT:-9997}"     # MediaMTX control API (loopback only)
DASH_PORT="${DASH_PORT:-8080}"   # web dashboard (loopback only)

# Bitrate for the synthetic 'pattern' stream
PATTERN_BITRATE="${PATTERN_BITRATE:-3M}"
